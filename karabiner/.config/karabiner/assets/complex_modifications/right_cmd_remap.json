https://ke-complex-modifications.pqrs.org/?q=remap%20right%20cmd%20to%20ctrl#swap_right_cmd_with_right_option
{
  "title": "Swap right cmd with right option",
  "maintainers": [
    "devnoname120"
  ],
  "rules": [
    {
      "description": "Swap right cmd with right option",
      "manipulators": [
        {
          "from": {
            "key_code": "left_control",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "right_command"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "right_command",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_control"
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}
